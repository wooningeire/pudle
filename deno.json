{
	"tasks": {
		"dev": "vite dev",
		"build": "vite build",
		"build:relative": "vite build --base=./",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
  "imports": {
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^2.0.2",
    "@sveltejs/adapter-static": "npm:@sveltejs/adapter-static@^3.0.10",
    "@sveltejs/kit": "npm:@sveltejs/kit@^2.63.0",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@^7.1.2",
    "sass": "npm:sass@^1.100.0",
    "svelte": "npm:svelte@^5.56.2",
    "svelte-check": "npm:svelte-check@^4.6.0",
    "typescript": "npm:typescript@^6.0.3",
    "vite": "npm:vite@^8.0.16"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "checkJs": true,
    "strict": true
  },
  "unstable": [
    "sloppy-imports"
  ]
}
